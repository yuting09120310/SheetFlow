@model IEnumerable<SheetFlow.Models.ApprovalWorkflow>
@{ ViewData["Title"] = "簽呈流程管理"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-diagram-3"></i> 簽呈流程管理</h4>
    <a asp-action="Edit" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> 新增簽呈流程
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mt-3">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>表單</th>
                    <th>適用部門</th>
                    <th>簽呈名稱</th>
                    <th>簽核步驟</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in Model)
                {
                    <tr>
                        <td>@w.FormTemplateName</td>
                        <td>
                            @if (string.IsNullOrEmpty(w.Department))
                            {
                                <span class="badge bg-secondary">全部部門</span>
                            }
                            else
                            {
                                <span class="badge bg-info">@w.Department</span>
                            }
                        </td>
                        <td><strong>@w.Name</strong></td>
                        <td>
                            @if (w.Steps.Any())
                            {
                                <div class="d-flex align-items-center gap-1 flex-wrap">
                                    @for (int i = 0; i < w.Steps.Count; i++)
                                    {
                                        var step = w.Steps[i];
                                        if (i > 0) { <span class="text-muted mx-1">→</span> }
                                        <span class="badge bg-primary">@step.ApproverLabel</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">尚未設定步驟</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> 編輯
                            </a>
                            <form asp-action="Delete" asp-route-id="@w.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('確定刪除此簽呈流程？')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">尚未建立任何簽呈流程</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
