@model DynamicFormSubmitViewModel
@{ ViewData["Title"] = "填寫 - " + Model.FormName; }

<h4 class="mb-3"><i class="bi bi-pencil-square"></i> @Model.FormName</h4>

<form asp-action="Submit" asp-route-id="@Model.FormTemplateId" method="post">
    @if (Model.AvailablePrerequisiteRequests.Any())
    {
        <div class="card mb-3 border-warning bg-warning bg-opacity-10">
            <div class="card-body">
                <div class="d-flex align-items-start gap-2">
                    <i class="bi bi-link-45deg text-warning fs-5 mt-1"></i>
                    <div class="flex-grow-1">
                        <strong class="d-block mb-1">前置表單（必填）</strong>
                        <p class="mb-2 small text-muted">此表單需要依賴已審核完成的 <strong>@Model.PrerequisiteTemplateName</strong> 才能提交</p>
                        <select name="prerequisiteRequestId" class="form-select form-select-sm" required style="max-width: 400px;">
                            <option value="">-- 請選擇已審核單據 --</option>
                            @foreach (var req in Model.AvailablePrerequisiteRequests)
                            {
                                <option value="@req.Id">@req.RequestNo - @req.FormName (@req.SubmittedAt?.ToString("yyyy-MM-dd"))</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    }
    <div class="card mb-3 border-primary bg-primary bg-opacity-10">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-auto"><i class="bi bi-person-badge text-primary"></i></div>
                <div class="col-auto"><strong>申請人：</strong>@Model.ApplicantName</div>
                <div class="col-auto text-muted">|</div>
                <div class="col-auto"><strong>部門：</strong>@Model.ApplicantDepartment</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3">
            @for (int i = 0; i < Model.Fields.Count; i++)
            {
                var field = Model.Fields[i];
                var skipField = field.FieldKey == "applicant" || field.FieldKey == "department";
                if (skipField) continue;

                if (field.FieldType == "Signature" && field.FieldKey != "acceptor") continue;

                var isFullWidth = field.FieldType == "Textarea" || field.FieldKey == "description" || field.FieldKey == "reason" || field.FieldKey == "remarks" || field.FieldKey == "specification";
                var colClass = isFullWidth ? "col-12" : "col-md-6 col-lg-4";
                var fieldName = field.FieldKey == "signature" ? "人員簽名" : field.FieldName;

                <div class="@colClass">
                    <label class="form-label fw-semibold small mb-1">
                        @fieldName
                        @if (field.IsRequired) { <span class="text-danger">*</span> }
                    </label>

                        @switch (field.FieldType)
                        {
                            case "Textarea":
                                <textarea name="field_@field.FieldId" class="form-control form-control-sm" rows="3"
                                          @(field.IsRequired ? "required" : "")>@field.Value</textarea>
                                break;
                            case "Number":
                                <input type="number" name="field_@field.FieldId" class="form-control form-control-sm"
                                       value="@field.Value" @(field.IsRequired ? "required" : "") step="any" />
                                break;
                            case "Date":
                                <input type="date" name="field_@field.FieldId" class="form-control form-control-sm"
                                       value="@(string.IsNullOrEmpty(field.Value) ? DateTime.Now.ToString("yyyy-MM-dd") : field.Value)" 
                                       @(field.IsRequired ? "required" : "") />
                                break;
                            case "Select":
                                var options = (field.OptionsJson ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                <select name="field_@field.FieldId" class="form-select form-select-sm" @(field.IsRequired ? "required" : "")>
                                    <option value="">-- 請選擇 --</option>
                                    @foreach (var opt in options)
                                    {
                                        <option value="@opt" selected="@(field.Value == opt)">@opt</option>
                                    }
                                </select>
                                break;
                        case "Signature":
                            <div class="signature-field-wrapper" data-field-id="@field.FieldId">
                                <div class="d-flex align-items-start gap-2">
                                    <div class="signature-preview-box flex-grow-1" onclick="openSignatureModal(@field.FieldId)">
                                        @if (!string.IsNullOrEmpty(field.Value))
                                        {
                                            <img src="@field.Value" class="signature-img" />
                                        }
                                        else
                                        {
                                            <span class="text-muted small">點擊此處簽名</span>
                                        }
                                    </div>
                                    <div class="d-flex flex-column gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMobileSignature(@field.FieldId)" title="使用手機/平板簽名">
                                            <i class="bi bi-qr-code"></i>
                                        </button>
                                        @if (!string.IsNullOrEmpty(field.Value))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="clearSignatureField(@field.FieldId)">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                                <input type="hidden" name="field_@field.FieldId" id="signature_input_@field.FieldId" value="@field.Value" />
                            </div>
                            break;
                        default:
                            <input type="text" name="field_@field.FieldId" class="form-control form-control-sm"
                                   value="@field.Value" @(field.IsRequired ? "required" : "") />
                            break;
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="mt-4 mb-5 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-send-fill"></i> 送出申請
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-x-lg"></i> 取消
        </a>
    </div>
</form>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3">
        <i class="bi bi-exclamation-triangle"></i> <div asp-validation-summary="All" class="d-inline"></div>
    </div>
}

<!-- Signature Modal -->
<div id="signatureModal" class="signature-modal d-none">
    <div class="signature-modal-content">
        <div class="signature-header">
            <h5 class="mb-0">請簽名</h5>
            <button type="button" class="btn-close" onclick="closeSignatureModal()"></button>
        </div>
        <div class="signature-body">
            <div class="signature-canvas-wrapper">
                <canvas id="signatureCanvas"></canvas>
            </div>
            <div class="signature-qr-section">
                <div class="qr-header">
                    <i class="bi bi-phone"></i> 行動裝置簽名
                </div>
                <img id="modalQrCode" src="" alt="QR Code" style="width: 150px; height: 150px;" />
                <small class="text-muted d-block mt-2">掃描後請橫向簽名</small>
                <div class="signature-sync-preview mt-2">
                    <img id="syncPreview" style="max-width: 100%; max-height: 80px; display: none;" />
                    <span id="syncText" class="text-muted small">等待簽名...</span>
                </div>
            </div>
        </div>
        <div class="signature-footer">
            <button type="button" class="btn btn-outline-secondary" onclick="clearSignature()">清除</button>
            <button type="button" class="btn btn-primary" onclick="saveSignature()">確定</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    let currentFieldId = null;
    let signaturePad = null;
    let connection = null;
    let currentSessionId = null;
    let currentQrCode = null;
    let mobileSignatureData = null; // Track signature from mobile

    async function ensureSession() {
        if (currentSessionId && currentQrCode) {
            return { sessionId: currentSessionId, qrCode: currentQrCode };
        }
        
        console.log('Creating new session...');
        const response = await fetch('/Signature/CreateSession', { method: 'POST' });
        if (!response.ok) {
            const errorText = await response.text();
            console.error('CreateSession failed:', response.status, errorText);
            throw new Error(`Failed to create session: ${response.status}`);
        }
        const data = await response.json();
        console.log('Session created:', { sessionId: data.sessionId, qrCodeLength: data.qrCode?.length });
        currentSessionId = data.sessionId;
        currentQrCode = data.qrCode;
        return { sessionId: currentSessionId, qrCode: currentQrCode };
    }

    async function openSignatureModal(fieldId) {
        currentFieldId = fieldId;
        const modal = document.getElementById('signatureModal');
        modal.classList.remove('d-none');

        const canvas = document.getElementById('signatureCanvas');
        const wrapper = canvas.parentElement;
        canvas.width = wrapper.clientWidth;
        canvas.height = wrapper.clientHeight;

        signaturePad = new SignaturePad(canvas, {
            backgroundColor: 'rgba(255, 255, 255, 0)',
            penColor: 'rgb(0, 0, 0)'
        });

        const input = document.getElementById(`signature_input_${fieldId}`);
        mobileSignatureData = null; // Reset mobile signature
        if (input.value) {
            signaturePad.fromDataURL(input.value);
            updateSyncPreview(input.value);
        } else {
            updateSyncPreview('');
        }

        try {
            const sessionData = await ensureSession();
            console.log('Setting QR code, length:', sessionData.qrCode?.length);
            document.getElementById('modalQrCode').src = sessionData.qrCode;
            await connectToSignatureHub(sessionData.sessionId);
        } catch (err) {
            console.error("Session error:", err);
            alert('無法啟動簽名會話，請重新整理頁面');
        }
    }

    async function openMobileSignature(fieldId) {
        currentFieldId = fieldId;
        try {
            const sessionData = await ensureSession();
            const url = `/Signature/Sign?sessionId=${sessionData.sessionId}`;
            window.open(url, '_blank', 'width=800,height=600');
            openSignatureModal(fieldId);
        } catch (err) {
            console.error("Mobile signature error:", err);
        }
    }

    async function connectToSignatureHub(sessionId) {
        if (connection) {
            await connection.stop();
        }

        connection = new signalR.HubConnectionBuilder()
            .withUrl("/signatureHub")
            .withAutomaticReconnect()
            .build();

        connection.on("SignatureUpdated", (imageData) => {
            updateSyncPreview(imageData);
            if (imageData && imageData.startsWith('data:image')) {
                // Store mobile signature
                mobileSignatureData = imageData;
                
                // Draw on local canvas so user can see it
                if (signaturePad) {
                    signaturePad.fromDataURL(imageData);
                }
                
                // Update hidden input
                const input = document.getElementById(`signature_input_${currentFieldId}`);
                input.value = imageData;
                
                // Update preview box
                const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
                const previewBox = wrapper.querySelector('.signature-preview-box');
                previewBox.innerHTML = `<img src="${imageData}" class="signature-img" />`;
                ensureResignButton(wrapper, currentFieldId);
            } else {
                // Mobile cleared signature - clear local canvas too
                mobileSignatureData = null;
                if (signaturePad) {
                    signaturePad.clear();
                }
                const input = document.getElementById(`signature_input_${currentFieldId}`);
                input.value = '';
                const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
                const previewBox = wrapper.querySelector('.signature-preview-box');
                previewBox.innerHTML = '<span class="text-muted small">點擊此處簽名</span>';
                const btn = wrapper.querySelector('.btn-resign');
                if (btn) btn.remove();
            }
        });

        try {
            await connection.start();
            await connection.invoke("JoinSession", sessionId);
        } catch (err) {
            console.error("SignalR connection failed:", err);
        }
    }

    function updateSyncPreview(imageData) {
        const preview = document.getElementById('syncPreview');
        const text = document.getElementById('syncText');
        if (imageData && imageData.startsWith('data:image')) {
            preview.src = imageData;
            preview.style.display = 'block';
            text.style.display = 'none';
        } else {
            preview.style.display = 'none';
            text.style.display = 'block';
            text.textContent = '等待簽名...';
        }
    }

    async function closeSignatureModal() {
        document.getElementById('signatureModal').classList.add('d-none');
        
        if (currentSessionId) {
            try {
                await fetch(`/Signature/EndSession?sessionId=${currentSessionId}`, { method: 'POST' });
            } catch (e) { console.error(e); }
        }

        if (connection) {
            await connection.stop();
            connection = null;
        }
        currentFieldId = null;
        currentSessionId = null;
        currentQrCode = null;
        mobileSignatureData = null;
    }

    function clearSignature() {
        if (signaturePad) signaturePad.clear();
        mobileSignatureData = null;
        updateSyncPreview('');
    }

    function saveSignature() {
        // Check if there's a signature from either local canvas or mobile
        const hasLocalSignature = signaturePad && !signaturePad.isEmpty();
        const hasMobileSignature = mobileSignatureData && mobileSignatureData.startsWith('data:image');
        
        if (!hasLocalSignature && !hasMobileSignature) {
            alert('請先簽名');
            return;
        }
        
        // Use mobile signature if available, otherwise use local canvas
        const dataUrl = hasMobileSignature ? mobileSignatureData : signaturePad.toDataURL('image/png');
        
        const input = document.getElementById(`signature_input_${currentFieldId}`);
        input.value = dataUrl;

        const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
        const previewBox = wrapper.querySelector('.signature-preview-box');
        previewBox.innerHTML = `<img src="${dataUrl}" class="signature-img" />`;
        ensureResignButton(wrapper, currentFieldId);

        closeSignatureModal();
    }

    function ensureResignButton(wrapper, fieldId) {
        let btn = wrapper.querySelector('.btn-resign');
        if (!btn) {
            btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn btn-sm btn-outline-danger btn-resign';
            btn.innerHTML = '<i class="bi bi-arrow-repeat"></i>';
            btn.onclick = () => clearSignatureField(fieldId);
            wrapper.querySelector('.d-flex').appendChild(btn);
        }
    }

    function clearSignatureField(fieldId) {
        if (confirm('確定要清除簽名並重新簽名嗎？')) {
            document.getElementById(`signature_input_${fieldId}`).value = '';
            const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${fieldId}"]`);
            const previewBox = wrapper.querySelector('.signature-preview-box');
            previewBox.innerHTML = '<span class="text-muted small">點擊此處簽名</span>';
            const btn = wrapper.querySelector('.btn-resign');
            if(btn) btn.remove();
            openSignatureModal(fieldId);
        }
    }

    window.addEventListener('resize', () => {
        if (!document.getElementById('signatureModal').classList.contains('d-none')) {
            const canvas = document.getElementById('signatureCanvas');
            const wrapper = canvas.parentElement;
            canvas.width = wrapper.clientWidth;
            canvas.height = wrapper.clientHeight;
        }
    });
</script>

<style>
    .signature-preview-box {
        border: 2px dashed #ccc;
        border-radius: 8px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background-color: #f8f9fa;
        transition: all 0.2s;
        overflow: hidden;
    }
    .signature-preview-box:hover {
        border-color: #0d6efd;
        background-color: #e9ecef;
    }
    .signature-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
    .signature-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.8);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .signature-modal-content {
        background: white;
        width: 90%;
        max-width: 1000px;
        height: 80vh;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .signature-header {
        padding: 15px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .signature-body {
        flex: 1;
        display: flex;
        overflow: hidden;
    }
    .signature-canvas-wrapper {
        flex: 2;
        position: relative;
        background: #fff;
        touch-action: none;
        border-right: 1px solid #eee;
    }
    .signature-qr-section {
        flex: 1;
        padding: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
    }
    .qr-header {
        font-weight: bold;
        margin-bottom: 15px;
        color: #0d6efd;
    }
    .signature-sync-preview {
        width: 100%;
        text-align: center;
        min-height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed #ccc;
        border-radius: 4px;
        background: white;
    }
    #signatureCanvas {
        width: 100%;
        height: 100%;
    }
    .signature-footer {
        padding: 15px;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    /* Mobile Landscape Optimization */
    @@media (max-width: 768px) {
        .signature-modal-content {
            width: 100vw;
            height: 100vh;
            max-width: none;
            border-radius: 0;
        }
        .signature-body {
            flex-direction: column;
        }
        .signature-canvas-wrapper {
            flex: 1;
            border-right: none;
            border-bottom: 1px solid #eee;
        }
        .signature-qr-section {
            flex: none;
            padding: 10px;
            max-height: 200px;
        }
    }
    @@media (max-width: 768px) and (orientation: portrait) {
        .signature-modal-content::before {
            content: "請將裝置旋轉為橫向以獲得最佳簽名體驗";
            display: block;
            background: #ffc107;
            color: #000;
            text-align: center;
            padding: 5px;
            font-size: 12px;
        }
    }
</style>
