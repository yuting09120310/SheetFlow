@{
    ViewData["Title"] = "掃描簽名";
}

<div class="text-center py-5">
    <h4 class="mb-4"><i class="bi bi-qr-code"></i> 行動裝置簽名</h4>
    <p class="text-muted mb-4">請使用手機或平板掃描下方 QR Code 進行簽名</p>
    
    <div class="card d-inline-block p-4 shadow-sm">
        <img id="qrCodeImage" src="/Signature/GetQrCode?sessionId=@ViewBag.SessionId" alt="QR Code" style="width: 250px; height: 250px;" />
        <div class="mt-3">
            <span class="badge bg-primary">等待連線...</span>
        </div>
    </div>

    <div class="mt-4">
        <div class="signature-preview-box mx-auto" style="max-width: 400px; height: 150px; border: 2px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
            <span class="text-muted" id="previewText">簽名將顯示於此</span>
            <img id="signaturePreview" style="max-width: 100%; max-height: 100%; display: none;" />
        </div>
    </div>

    <div class="mt-3">
        <button type="button" class="btn btn-outline-primary" onclick="requestSignature()">
            <i class="bi bi-bell"></i> 提醒簽名
        </button>
        <button type="button" class="btn btn-outline-secondary ms-2" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i> 重新產生 QR Code
        </button>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    const sessionId = '@ViewBag.SessionId';
    let connection = null;

    async function initSignalR() {
        connection = new signalR.HubConnectionBuilder()
            .withUrl("/signatureHub")
            .withAutomaticReconnect()
            .build();

        connection.on("SignatureUpdated", (imageData) => {
            const preview = document.getElementById('signaturePreview');
            const text = document.getElementById('previewText');
            if (imageData && imageData.startsWith('data:image')) {
                preview.src = imageData;
                preview.style.display = 'block';
                text.style.display = 'none';
            } else {
                preview.style.display = 'none';
                text.style.display = 'block';
                text.textContent = '簽名將顯示於此';
            }
        });

        try {
            await connection.start();
            await connection.invoke("JoinSession", sessionId);
        } catch (err) {
            console.error(err);
        }
    }

    async function requestSignature() {
        if (connection) {
            await connection.invoke("RequestSignature", sessionId);
        }
    }

    window.addEventListener('load', initSignalR);
</script>

<style>
    .signature-preview-box {
        transition: all 0.3s;
    }
</style>
