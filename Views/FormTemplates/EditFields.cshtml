@model FormFieldSettingsViewModel
@{ ViewData["Title"] = "欄位設定"; }

<h4><i class="bi bi-gear"></i> 欄位設定 - @Model.FormName</h4>

<form asp-action="EditFields" method="post">
    <input type="hidden" asp-for="FormTemplateId" />

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">排序</th>
                        <th>欄位名稱</th>
                        <th>欄位代碼</th>
                        <th style="width:130px">型態</th>
                        <th style="width:70px">必填</th>
                        <th style="width:70px">顯示</th>
                        <th>選項 / 預設值</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Fields.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="@Model.Fields[i].Id" />
                                <input type="hidden" asp-for="@Model.Fields[i].FormTemplateId" />
                                <input type="hidden" asp-for="@Model.Fields[i].FieldKey" />
                                <input asp-for="@Model.Fields[i].SortOrder" class="form-control form-control-sm" style="width:60px" />
                            </td>
                            <td>
                                <input asp-for="@Model.Fields[i].FieldName" class="form-control form-control-sm" />
                            </td>
                            <td><code>@Model.Fields[i].FieldKey</code></td>
                            <td>
                                <select asp-for="@Model.Fields[i].FieldType" class="form-select form-select-sm field-type-select">
                                    <option value="Text">Text</option>
                                    <option value="Textarea">Textarea</option>
                                    <option value="Number">Number</option>
                                    <option value="Date">Date</option>
                                    <option value="Select">Select</option>
                                </select>
                            </td>
                            <td class="text-center">
                                <input asp-for="@Model.Fields[i].IsRequired" class="form-check-input" />
                            </td>
                            <td class="text-center">
                                <input asp-for="@Model.Fields[i].IsVisible" class="form-check-input" />
                            </td>
                            <td>
                                <input asp-for="@Model.Fields[i].OptionsText" class="form-control form-control-sm options-input" placeholder="選項 (逗號分隔)" style="@(Model.Fields[i].FieldType != "Select" ? "display:none" : "")" />
                                <input asp-for="@Model.Fields[i].DefaultValue" class="form-control form-control-sm" placeholder="預設值" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i> 儲存設定
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
    </div>
</form>

@section Scripts {
    <script>
        document.querySelectorAll('.field-type-select').forEach(function(select) {
            select.addEventListener('change', function() {
                var row = this.closest('tr');
                var optionsInput = row.querySelector('.options-input');
                optionsInput.style.display = this.value === 'Select' ? '' : 'none';
            });
        });
    </script>
}
