@model IEnumerable<SheetFlow.Models.FormTemplate>
@{ ViewData["Title"] = "表單樣板管理"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-collection"></i> 表單樣板管理</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> 新增表單
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>名稱</th>
                    <th>說明</th>
                    <th>狀態</th>
                    <th>建立時間</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="fw-bold">@t.Name</td>
                        <td class="text-muted">@t.Description</td>
                        <td>
                            @if (t.IsActive)
                            {
                                <span class="badge bg-success">啟用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">停用</span>
                            }
                        </td>
                        <td class="text-muted">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a asp-action="EditFields" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-gear"></i> 欄位設定
                            </a>
                            <form asp-action="ToggleActive" asp-route-id="@t.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-@(t.IsActive ? "warning" : "success")">
                                    <i class="bi bi-@(t.IsActive ? "pause" : "play")"></i>
                                    @(t.IsActive ? "停用" : "啟用")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">尚無表單樣板</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
