@model IEnumerable<SheetFlow.Models.FormRequest>
@{ ViewData["Title"] = "待審核"; }

<h4><i class="bi bi-check2-square"></i> 待審核申請</h4>

<div class="card mt-3">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>申請單號</th>
                    <th>表單名稱</th>
                    <th>申請人</th>
                    <th>目前步驟</th>
                    <th>狀態</th>
                    <th>送出時間</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    var stepMap = ViewBag.StepMap as Dictionary<long, SheetFlow.Models.ApprovalStepInstance>;
                    var currentStep = stepMap?.ContainsKey(r.Id) == true ? stepMap[r.Id] : null;
                    var totalSteps = r.Status == "Approved" ? 0 : 0;

                    <tr>
                        <td><code>@r.RequestNo</code></td>
                        <td>@r.FormName</td>
                        <td>@r.ApplicantName</td>
                        <td>
                            @if (currentStep != null)
                            {
                                <span class="badge bg-warning text-dark">
                                    第 @currentStep.StepOrder 步：@currentStep.ApproverLabel
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@await Html.PartialAsync("_StatusBadge", r.Status)</td>
                        <td class="text-muted">@r.SubmittedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a asp-controller="Requests" asp-action="Detail" asp-route-id="@r.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> 審核
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">暫無待審核申請</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
