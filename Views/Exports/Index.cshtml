@model ExportViewModel
@{ ViewData["Title"] = "匯出 Excel"; }

<h4><i class="bi bi-download"></i> 匯出申請資料</h4>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="ExportExcel" method="post">
                    <div class="mb-3">
                        <label asp-for="FormTemplateId" class="form-label"></label>
                        <select asp-for="FormTemplateId" class="form-select">
                            <option value="">-- 全部表單 --</option>
                            @foreach (var t in Model.Templates)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="">-- 全部狀態 --</option>
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-file-earmark-excel"></i> 匯出 Excel
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
