@model RequestDetailViewModel
@{
    ViewData["Title"] = "申請明細";
    var isApprover = User.IsInRole("Manager") || User.IsInRole("Admin");
    var isOwner = Model.Request.ApplicantId.ToString() == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = long.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
    var currentStep = Model.StepInstances.FirstOrDefault(s => s.Status == "Pending" && s.AssignedUserId == currentUserId);
    var canApprove = isApprover && Model.Request.Status == "Pending" && currentStep != null;

    var signatureFieldMap = new Dictionary<string, string>
    {
        { "acceptor", "驗收人" },
        { "acceptance_unit_manager", "驗收單位主管" },
        { "request_unit_manager", "請購單位主管" }
    };

    string GetCurrentStepSignatureFieldKey()
    {
        if (currentStep == null) return "";
        
        if (Model.Request.FormName == "固定資產驗收單")
        {
            return currentStep.StepOrder switch
            {
                1 => "acceptance_unit_manager",
                2 => "request_unit_manager",
                _ => ""
            };
        }
        
        if (Model.Request.FormName == "請購單")
        {
            return currentStep.StepOrder switch
            {
                1 => "department_manager_signature",
                2 => "it_manager_signature",
                3 => "accounting_manager_signature",
                _ => ""
            };
        }
        
        var unsignedSignatureFields = Model.Fields
            .Where(f => f.FieldType == "Signature")
            .Where(f => {
                var v = Model.Values.FirstOrDefault(val => val.FieldKey == f.FieldKey);
                return v == null || string.IsNullOrEmpty(v.FieldValue) || !v.FieldValue.StartsWith("data:image");
            })
            .OrderBy(f => f.SortOrder)
            .ToList();
        
        return unsignedSignatureFields.FirstOrDefault()?.FieldKey ?? "";
    }

    var currentSignatureFieldKey = GetCurrentStepSignatureFieldKey();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-file-text"></i> 申請明細</h4>
    <div>
        @if (isApprover && Model.Request.Status == "Pending")
        {
            <a asp-controller="Approvals" asp-action="Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-left"></i> 回待審核
            </a>
        }
        <a asp-controller="Requests" asp-action="MyRequests" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-list"></i> 回列表
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-info-circle"></i> 基本資訊
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">申請單號</div>
                    <div class="col-sm-9"><code>@Model.Request.RequestNo</code></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">表單名稱</div>
                    <div class="col-sm-9">@Model.Request.FormName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">申請人</div>
                    <div class="col-sm-9">@Model.Request.ApplicantName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">送出時間</div>
                    <div class="col-sm-9">@Model.Request.SubmittedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">狀態</div>
                    <div class="col-sm-9">@await Html.PartialAsync("_StatusBadge", Model.Request.Status)</div>
                </div>
            </div>
        </div>

        @if (Model.Dependencies.Any())
        {
            <div class="card mb-3 border-info">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-link-45deg"></i> 關聯表單
                </div>
                <div class="card-body">
                    @foreach (var dep in Model.Dependencies)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-check text-success"></i>
                            <span>前置單據：<a asp-action="Detail" asp-route-id="@dep.RequiredRequestId"><code>@dep.RequiredRequestNo</code></a> (@dep.RequiredFormName)</span>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-table"></i> 表單內容
            </div>
            <div class="card-body">
                @foreach (var field in Model.Fields)
                {
                    var value = Model.Values.FirstOrDefault(v => v.FieldKey == field.FieldKey);
                    var displayValue = value?.FieldValue ?? "-";
                    var isSignature = field.FieldType == "Signature" && displayValue.StartsWith("data:image");
                    var fieldName = field.FieldKey == "signature" ? "人員簽名" : field.FieldName;
                    var isCurrentStepSignature = canApprove && field.FieldKey == currentSignatureFieldKey;

                    if (Model.Request.FormName == "固定資產驗收單" && field.FieldType == "Signature")
                    {
                        if (!isSignature && !isCurrentStepSignature)
                        {
                            continue;
                        }
                    }

                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">@fieldName</div>
                        <div class="col-sm-9">
                            @if (field.FieldType != "Signature")
                            {
                                @displayValue
                            }
                            else if (isSignature)
                            {
                                <img src="@displayValue" style="max-height: 80px; border: 1px solid #ddd; padding: 2px; background: white;" />
                                <span class="badge bg-secondary ms-2">已簽名</span>
                            }
                            else if (isCurrentStepSignature)
                            {
                                <div class="signature-field-wrapper" data-field-id="@field.Id">
                                    <div class="d-flex align-items-start gap-2">
                                        <div class="signature-preview-box flex-grow-1" onclick="openSignatureModal(@field.Id)">
                                            <span class="text-muted small">點擊此處簽名</span>
                                        </div>
                                        <div class="d-flex flex-column gap-1">
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMobileSignature(@field.Id)" title="使用手機/平板簽名">
                                                <i class="bi bi-qr-code"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <input type="hidden" name="approver_signature" id="signature_input_@field.Id" value="" />
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">尚未簽名</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (Model.Request.Status == "Rejected" && isOwner)
        {
            <div class="card mb-3 border-danger">
                <div class="card-header bg-danger text-white">
                    <i class="bi bi-arrow-return-left"></i> 重新送出
                </div>
                <div class="card-body">
                    <form asp-action="Resubmit" asp-route-id="@Model.Request.Id" method="post">
                        @foreach (var field in Model.Fields)
                        {
                            var value = Model.Values.FirstOrDefault(v => v.FieldKey == field.FieldKey);
                            <div class="mb-2">
                                <label class="form-label">@field.FieldName</label>
                                @switch (field.FieldType)
                                {
                                    case "Textarea":
                                        <textarea name="field_@field.Id" class="form-control" rows="2">@value?.FieldValue</textarea>
                                        break;
                                    case "Number":
                                        <input type="number" name="field_@field.Id" class="form-control" value="@value?.FieldValue" />
                                        break;
                                    case "Date":
                                        <input type="date" name="field_@field.Id" class="form-control" value="@value?.FieldValue" />
                                        break;
                                    case "Select":
                                        var opts = (field.OptionsJson ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                        <select name="field_@field.Id" class="form-select">
                                            @foreach (var o in opts)
                                            {
                                                <option value="@o" selected="@(value?.FieldValue == o)">@o</option>
                                            }
                                        </select>
                                        break;
                                    default:
                                        <input type="text" name="field_@field.Id" class="form-control" value="@value?.FieldValue" />
                                        break;
                                }
                            </div>
                        }
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-send"></i> 重新送出
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (canApprove)
        {
            <div class="card mb-3 border-success">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-check2-square"></i> 審核操作
                </div>
                <div class="card-body">
                    <form asp-controller="Approvals" asp-action="Approve" asp-route-id="@Model.Request.Id" method="post" id="approveForm">
                        <input type="hidden" name="signature_field_key" value="@currentSignatureFieldKey" />
                        <input type="hidden" name="signature_field_id" id="approve_signature_field_id" value="" />
                        <input type="hidden" name="signature_value" id="approve_signature_value" value="" />
                        <div class="row g-2">
                            <div class="col-auto">
                                <button type="submit" class="btn btn-success" id="approveBtn">
                                    <i class="bi bi-check-lg"></i> 簽名並核准
                                </button>
                            </div>
                            <div class="col">
                                <div class="input-group">
                                    <input type="text" name="comment" class="form-control" placeholder="退回原因" id="rejectComment" />
                                    <button type="button" class="btn btn-danger" id="rejectBtn">
                                        <i class="bi bi-x-lg"></i> 退回
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                    <form asp-controller="Approvals" asp-action="Reject" asp-route-id="@Model.Request.Id" method="post" id="rejectForm" style="display: none;">
                        <input type="hidden" name="comment" id="rejectCommentHidden" />
                    </form>
                </div>
            </div>
        }
        else if (isApprover && Model.Request.Status == "Pending" && !Model.StepInstances.Any(s => s.AssignedUserId == currentUserId && s.Status == "Pending"))
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> 此申請單目前不在您的簽核步驟中
            </div>
        }
    </div>

    <div class="col-md-4">
        @if (Model.StepInstances.Any())
        {
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-signpost-split"></i> 簽核流程
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var step in Model.StepInstances.OrderBy(s => s.StepOrder))
                        {
                            var isCurrentStep = step.Status == "Pending";
                            var isCompleted = step.Status == "Approved";
                            var isRejected = step.Status == "Rejected";
                            var isSkipped = step.Status == "Skipped";
                            var icon = isCompleted ? "bi-check-circle-fill text-success" :
                                       isRejected ? "bi-x-circle-fill text-danger" :
                                       isSkipped ? "bi-skip-forward-fill text-secondary" :
                                       isCurrentStep ? "bi-hourglass-split text-warning" : "bi-circle text-muted";
                            var bgClass = isCurrentStep ? "bg-warning bg-opacity-10" : isSkipped ? "bg-light opacity-50" : "";

                            <div class="list-group-item @bgClass">
                                <div class="d-flex align-items-center">
                                    <i class="bi @icon me-2 fs-5"></i>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <strong>第 @step.StepOrder 步：@step.ApproverLabel</strong>
                                            <span class="badge @(isCompleted ? "bg-success" : isRejected ? "bg-danger" : isSkipped ? "bg-secondary" : "bg-warning text-dark")">
                                                @(isCompleted ? "已核准" : isRejected ? "已退回" : isSkipped ? "已跳過" : "待簽核")
                                            </span>
                                        </div>
                                        @if (step.AssignedUserName != null)
                                        {
                                            <div class="text-muted small">簽核者：@step.AssignedUserName</div>
                                        }
                                        @if (!string.IsNullOrEmpty(step.Comment))
                                        {
                                            <div class="mt-1 p-1 bg-light rounded small">@step.Comment</div>
                                        }
                                        @if (step.ApprovedAt.HasValue)
                                        {
                                            <div class="text-muted small">@step.ApprovedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                        }
                                        @if (step.RejectedAt.HasValue)
                                        {
                                            <div class="text-muted small">@step.RejectedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <i class="bi bi-clock-history"></i> 審核紀錄
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @foreach (var log in Model.ApprovalLogs)
                    {
                        var icon = log.Action switch
                        {
                            "Submit" => "bi-send text-primary",
                            "Approve" => "bi-check-circle text-success",
                            "Reject" => "bi-x-circle text-danger",
                            "Resubmit" => "bi-arrow-return-left text-info",
                            _ => "bi-record"
                        };
                        <div class="list-group-item">
                            <div class="d-flex align-items-center">
                                <i class="bi @icon me-2 fs-5"></i>
                                <div>
                                    <strong>@log.Action</strong>
                                    <div class="text-muted small">@log.ActorName</div>
                                    <div class="text-muted small">@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                                    @if (!string.IsNullOrEmpty(log.Comment))
                                    {
                                        <div class="mt-1 p-1 bg-light rounded small">@log.Comment</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @if (!Model.ApprovalLogs.Any())
                    {
                        <div class="list-group-item text-muted text-center">尚無紀錄</div>
                    }
                </div>
            </div>
        </div>

        @if (isApprover || isOwner)
        {
            <div class="mt-2">
                <form asp-controller="Exports" asp-action="ExportSingle" asp-route-id="@Model.Request.Id" method="post">
                    <button type="submit" class="btn btn-outline-success btn-sm w-100">
                        <i class="bi bi-download"></i> 匯出 Excel
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@if (canApprove)
{
    <!-- Signature Modal -->
    <div id="signatureModal" class="signature-modal d-none">
        <div class="signature-modal-content">
            <div class="signature-header">
                <h5 class="mb-0">請簽名</h5>
                <button type="button" class="btn-close" onclick="closeSignatureModal()"></button>
            </div>
            <div class="signature-body">
                <div class="signature-canvas-wrapper">
                    <canvas id="signatureCanvas"></canvas>
                </div>
                <div class="signature-qr-section">
                    <div class="qr-header">
                        <i class="bi bi-phone"></i> 行動裝置簽名
                    </div>
                    <img id="modalQrCode" src="" alt="QR Code" style="width: 150px; height: 150px;" />
                    <small class="text-muted d-block mt-2">掃描後請橫向簽名</small>
                    <div class="signature-sync-preview mt-2">
                        <img id="syncPreview" style="max-width: 100%; max-height: 80px; display: none;" />
                        <span id="syncText" class="text-muted small">等待簽名...</span>
                    </div>
                </div>
            </div>
            <div class="signature-footer">
                <button type="button" class="btn btn-outline-secondary" onclick="clearSignature()">清除</button>
                <button type="button" class="btn btn-primary" onclick="saveSignature()">確定</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        let currentFieldId = null;
        let signaturePad = null;
        let connection = null;
        let currentSessionId = null;
        let currentQrCode = null;
        let mobileSignatureData = null;

        async function ensureSession() {
            if (currentSessionId && currentQrCode) {
                return { sessionId: currentSessionId, qrCode: currentQrCode };
            }
            
            console.log('Creating new session...');
            const response = await fetch('/Signature/CreateSession', { method: 'POST' });
            if (!response.ok) {
                const errorText = await response.text();
                console.error('CreateSession failed:', response.status, errorText);
                throw new Error(`Failed to create session: ${response.status}`);
            }
            const data = await response.json();
            console.log('Session created:', { sessionId: data.sessionId, qrCodeLength: data.qrCode?.length });
            currentSessionId = data.sessionId;
            currentQrCode = data.qrCode;
            return { sessionId: currentSessionId, qrCode: currentQrCode };
        }

        async function openSignatureModal(fieldId) {
            currentFieldId = fieldId;
            const modal = document.getElementById('signatureModal');
            modal.classList.remove('d-none');

            const canvas = document.getElementById('signatureCanvas');
            const wrapper = canvas.parentElement;
            canvas.width = wrapper.clientWidth;
            canvas.height = wrapper.clientHeight;

            signaturePad = new SignaturePad(canvas, {
                backgroundColor: 'rgba(255, 255, 255, 0)',
                penColor: 'rgb(0, 0, 0)'
            });

            mobileSignatureData = null;
            updateSyncPreview('');

            try {
                const sessionData = await ensureSession();
                console.log('Setting QR code, length:', sessionData.qrCode?.length);
                document.getElementById('modalQrCode').src = sessionData.qrCode;
                await connectToSignatureHub(sessionData.sessionId);
            } catch (err) {
                console.error("Session error:", err);
                alert('無法啟動簽名會話，請重新整理頁面');
            }
        }

        async function openMobileSignature(fieldId) {
            currentFieldId = fieldId;
            try {
                const sessionData = await ensureSession();
                const url = `/Signature/Sign?sessionId=${sessionData.sessionId}`;
                window.open(url, '_blank', 'width=800,height=600');
                openSignatureModal(fieldId);
            } catch (err) {
                console.error("Mobile signature error:", err);
            }
        }

        async function connectToSignatureHub(sessionId) {
            if (connection) {
                await connection.stop();
            }

            connection = new signalR.HubConnectionBuilder()
                .withUrl("/signatureHub")
                .withAutomaticReconnect()
                .build();

            connection.on("SignatureUpdated", (imageData) => {
                updateSyncPreview(imageData);
                if (imageData && imageData.startsWith('data:image')) {
                    mobileSignatureData = imageData;
                    if (signaturePad) {
                        signaturePad.fromDataURL(imageData);
                    }
                    const input = document.getElementById(`signature_input_${currentFieldId}`);
                    input.value = imageData;
                    const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
                    const previewBox = wrapper.querySelector('.signature-preview-box');
                    previewBox.innerHTML = `<img src="${imageData}" class="signature-img" />`;
                } else {
                    mobileSignatureData = null;
                    if (signaturePad) {
                        signaturePad.clear();
                    }
                    const input = document.getElementById(`signature_input_${currentFieldId}`);
                    input.value = '';
                    const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
                    const previewBox = wrapper.querySelector('.signature-preview-box');
                    previewBox.innerHTML = '<span class="text-muted small">點擊此處簽名</span>';
                }
            });

            try {
                await connection.start();
                await connection.invoke("JoinSession", sessionId);
            } catch (err) {
                console.error("SignalR connection failed:", err);
            }
        }

        function updateSyncPreview(imageData) {
            const preview = document.getElementById('syncPreview');
            const text = document.getElementById('syncText');
            if (imageData && imageData.startsWith('data:image')) {
                preview.src = imageData;
                preview.style.display = 'block';
                text.style.display = 'none';
            } else {
                preview.style.display = 'none';
                text.style.display = 'block';
                text.textContent = '等待簽名...';
            }
        }

        async function closeSignatureModal() {
            document.getElementById('signatureModal').classList.add('d-none');
            
            if (currentSessionId) {
                try {
                    await fetch(`/Signature/EndSession?sessionId=${currentSessionId}`, { method: 'POST' });
                } catch (e) { console.error(e); }
            }

            if (connection) {
                await connection.stop();
                connection = null;
            }
            currentFieldId = null;
            currentSessionId = null;
            currentQrCode = null;
            mobileSignatureData = null;
        }

        function clearSignature() {
            if (signaturePad) signaturePad.clear();
            mobileSignatureData = null;
            updateSyncPreview('');
        }

        function saveSignature() {
            const hasLocalSignature = signaturePad && !signaturePad.isEmpty();
            const hasMobileSignature = mobileSignatureData && mobileSignatureData.startsWith('data:image');
            
            if (!hasLocalSignature && !hasMobileSignature) {
                alert('請先簽名');
                return;
            }
            
            const dataUrl = hasMobileSignature ? mobileSignatureData : signaturePad.toDataURL('image/png');
            
            const input = document.getElementById(`signature_input_${currentFieldId}`);
            input.value = dataUrl;

            document.getElementById('approve_signature_field_id').value = currentFieldId;
            document.getElementById('approve_signature_value').value = dataUrl;

            const wrapper = document.querySelector(`.signature-field-wrapper[data-field-id="${currentFieldId}"]`);
            const previewBox = wrapper.querySelector('.signature-preview-box');
            previewBox.innerHTML = `<img src="${dataUrl}" class="signature-img" />`;

            closeSignatureModal();
        }

        document.getElementById('rejectBtn').addEventListener('click', function() {
            const comment = document.getElementById('rejectComment').value;
            if (!comment) {
                alert('請填寫退回原因');
                return;
            }
            if (confirm('確定要退回此申請？')) {
                document.getElementById('rejectCommentHidden').value = comment;
                document.getElementById('rejectForm').submit();
            }
        });

        document.getElementById('approveForm').addEventListener('submit', function(e) {
            const signatureValue = document.getElementById('approve_signature_value').value;
            if (!signatureValue) {
                e.preventDefault();
                alert('請先簽名後再核准');
            }
        });

        window.addEventListener('resize', () => {
            if (!document.getElementById('signatureModal').classList.contains('d-none')) {
                const canvas = document.getElementById('signatureCanvas');
                const wrapper = canvas.parentElement;
                canvas.width = wrapper.clientWidth;
                canvas.height = wrapper.clientHeight;
            }
        });
    </script>

    <style>
        .signature-preview-box {
            border: 2px dashed #ccc;
            border-radius: 8px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            background-color: #f8f9fa;
            transition: all 0.2s;
            overflow: hidden;
        }
        .signature-preview-box:hover {
            border-color: #0d6efd;
            background-color: #e9ecef;
        }
        .signature-img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
        .signature-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.8);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .signature-modal-content {
            background: white;
            width: 90%;
            max-width: 1000px;
            height: 80vh;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .signature-header {
            padding: 15px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
